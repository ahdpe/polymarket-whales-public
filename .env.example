# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Insider alerts: Telegram channel ID for publishing signals (optional; can also set via bot command)
# INSIDER_ALERTS_CHANNEL_ID=-1003507639879
# Position tracker: before marking buffer trades SOLD_FROM_BUFFER, require N empty API scans (default 3, pause 1.5s)
# INSIDER_POSITION_CONFIRM_ROUNDS=3
# INSIDER_POSITION_CONFIRM_PAUSE_SEC=1.5
# Insider scenario recalculation interval (seconds). Default 900 = 15 minutes.
# INSIDER_SCENARIO_CHECK_INTERVAL_SEC=900

# Polymarket CLOB API credentials
POLY_API_KEY=your_poly_api_key
POLY_API_SECRET=your_poly_api_secret
POLY_PASSPHRASE=your_poly_passphrase
POLY_WALLET_ADDRESS=your_wallet_address
POLY_PRIVATE_KEY=your_private_key

# PolygonScan API Key (Optional, for accurate wallet age)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Status Dashboard (Optional)
STATUS_ENABLED=true
STATUS_PORT=5000
